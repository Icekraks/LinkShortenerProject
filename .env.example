# Core database connection
DATABASE_URL=postgresql://<user>:<password>@<your-neon-host>.neon.tech/<db>?sslmode=verify-full

# Required for shortcode generation
HASHIDS_SALT=replace-with-a-long-random-secret

# Required for signing auth session tokens
AUTH_SESSION_SECRET=replace-with-a-long-random-secret

# Optional: base URL used when constructing email verification/reset links
# Falls back to the request origin if not set (fine for most local setups)
# APP_BASE_URL=https://yourdomain.com

# Optional: Resend credentials for transactional email (verification, password reset)
# Emails are silently skipped when these are not set
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# Optional: override SSL behavior
# DATABASE_SSL=true

# Optional: comma-separated reserved shortcodes (case-insensitive)
SHORT_CODE_BLACKLIST=admin,api,www,root,support,help

# Optional: used by scheduled cleanup route in deployment
# CRON_SECRET=replace-with-a-long-random-secret

# Optional: used only for integration tests
# INTEGRATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/link_shortener_test
